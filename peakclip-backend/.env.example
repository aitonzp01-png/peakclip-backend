# ─── REQUIRED ───
OPENAI_API_KEY=sk-your-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJh...service_role_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

STRIPE_PRICE_CREATOR=price_abc123def
STRIPE_PRICE_PRO=price_ghi789jkl

# ─── YOUTUBE DOWNLOAD (optional) ───
# Generate locally: yt-dlp --username oauth https://youtube.com/watch?v=test
# Then: base64 ~/.cache/yt-dlp/tokens.json
YOUTUBE_OAUTH_TOKENS_B64=base64_encoded_tokens_json
# Cookies from a logged-in browser (Netscape format, base64 encoded)
YOUTUBE_COOKIES_B64=base64_encoded_cookies
# Residential/rotating proxy (e.g. Webshare)
YOUTUBE_PROXY=http://user:pass@host:port

# ─── DEPLOY ───
FRONTEND_URL=https://your-app.vercel.app
PUBLIC_URL=https://your-backend.onrender.com
